<Window x:Class="ForgeBGM.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="ForgeBGM - AI Music Generation Assistant" Height="800" Width="1200"
        Background="#0A0B10" Foreground="#F8FAFC"
        Icon="Resources/AppIcon.png">
    <Window.Resources>
        <!-- Custom Styles -->
        <Style x:Key="GlassCard" TargetType="Border">
            <Setter Property="Background" Value="#191B26"/>
            <Setter Property="Opacity" Value="0.95"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderBrush" Value="#22FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="20" Color="Black" Opacity="0.3" ShadowDepth="4"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HeaderTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style x:Key="HeaderSubtitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#4F46E5"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#6366F1"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                <TextBlock Text="Forge" FontSize="24" FontWeight="ExtraBold" Foreground="White"/>
                <TextBlock Text="BGM" FontSize="24" FontWeight="ExtraBold" Foreground="#4F46E5"/>
                <Border Background="#4F46E5" CornerRadius="4" Margin="10,0,0,0" Padding="5,2" VerticalAlignment="Center">
                    <TextBlock Text="v1.1 Advanced" FontSize="9" Foreground="White"/>
                </Border>
                <TextBlock Text="● Online" Foreground="#10B981" FontSize="11" VerticalAlignment="Center" Margin="15,0,0,0"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                <Button x:Name="LangBtn" Content="JP / EN" Background="Transparent" Foreground="#94A3B8" 
                        BorderBrush="#33FFFFFF" BorderThickness="1" Padding="10,2" Click="LangBtn_Click"/>
            </StackPanel>
        </DockPanel>

        <!-- Main Content (3 Columns) -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Column 1: History -->
            <Border Grid.Column="0" Style="{StaticResource GlassCard}" Padding="10">
                <DockPanel>
                    <TextBlock x:Name="TxtHistoryHeader" Text="🕒 History" Style="{StaticResource HeaderTitle}" DockPanel.Dock="Top"/>
                    <ListBox x:Name="HistoryList" Background="Transparent" BorderThickness="0" 
                             Foreground="#CBD5E1" SelectionChanged="HistoryList_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontSize="11" Margin="2"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Column 2: Control Panel -->
            <StackPanel Grid.Column="1">
                <Border Style="{StaticResource GlassCard}" Padding="15">
                    <StackPanel>
                        <TextBlock x:Name="TxtInputHeader" Text="🎹 Input Prompt" Style="{StaticResource HeaderTitle}"/>
                        <TextBlock x:Name="TxtInputSub" Text="楽曲のイメージを入力してください" Style="{StaticResource HeaderSubtitle}"/>
                        <TextBox x:Name="UserInput" Height="140" AcceptsReturn="True" TextWrapping="Wrap" 
                                 Background="#080808" Foreground="White" BorderBrush="#33FFFFFF" Padding="8"/>
                        
                        <WrapPanel Margin="0,10,0,0">
                            <Button x:Name="BtnBoss" Content="Boss Battle" Margin="0,0,4,4" Padding="8,4" Click="Preset_Click" Tag="boss"/>
                            <Button x:Name="BtnLofi" Content="Lo-Fi Chill" Margin="0,0,4,4" Padding="8,4" Click="Preset_Click" Tag="lofi"/>
                            <Button x:Name="BtnCyber" Content="Cyberpunk" Margin="0,0,4,4" Padding="8,4" Click="Preset_Click" Tag="cyber"/>
                        </WrapPanel>

                        <Button x:Name="GenerateBtn" Content="Generate Optimized Prompt" Style="{StaticResource PrimaryButton}" 
                                Margin="0,10,0,0" Height="40" Click="GenerateBtn_Click"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource GlassCard}" Padding="15">
                    <StackPanel>
                        <TextBlock x:Name="TxtSkillHeader" Text="⚡ Active SKILLs" Style="{StaticResource HeaderTitle}"/>
                        <TextBlock x:Name="TxtSkillSub" Text="自動発動したスキル" Style="{StaticResource HeaderSubtitle}"/>
                        <ItemsControl x:Name="SkillList">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#1A10B981" BorderBrush="#4D10B981" BorderThickness="1" 
                                            CornerRadius="6" Padding="8,4" Margin="0,0,8,8">
                                        <TextBlock x:Name="SkillNameText" Text="{Binding Name}" Foreground="#10B981" FontSize="11"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Column 3: Output -->
            <StackPanel Grid.Column="2">
                <Border Style="{StaticResource GlassCard}" Padding="15">
                    <StackPanel>
                        <DockPanel LastChildFill="False">
                            <TextBlock x:Name="TxtPromptHeader" Text="📝 Optimized Prompt (v2.0)" Style="{StaticResource HeaderTitle}" DockPanel.Dock="Left"/>
                            <Button Content="📋" Background="Transparent" BorderThickness="0" Foreground="#94A3B8" 
                                    DockPanel.Dock="Right" Click="CopyPrompt_Click"/>
                        </DockPanel>
                        <TextBox x:Name="PromptOutput" Height="140" IsReadOnly="True" TextWrapping="Wrap" 
                                 Background="#080808" Foreground="#A5F3FC" BorderBrush="#33FFFFFF" Padding="8" FontFamily="Consolas" FontSize="12"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource GlassCard}" Padding="15">
                    <StackPanel>
                        <DockPanel LastChildFill="False">
                            <TextBlock x:Name="TxtReportHeader" Text="📊 Generation Report" Style="{StaticResource HeaderTitle}" DockPanel.Dock="Left"/>
                            <Button Content="📋" Background="Transparent" BorderThickness="0" Foreground="#94A3B8" 
                                    DockPanel.Dock="Right" Click="CopyReport_Click"/>
                        </DockPanel>
                        <TextBox x:Name="ReportOutput" Height="220" IsReadOnly="True" TextWrapping="Wrap" 
                                 Background="#080808" Foreground="#CBD5E1" BorderBrush="#33FFFFFF" Padding="8" FontFamily="Consolas" FontSize="10.5"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <!-- Footer -->
        <TextBlock Grid.Row="2" Text="© 2026 ForgeBGM Advanced System. v1.1 Hybrid Edition." 
                   HorizontalAlignment="Center" Foreground="#94A3B8" FontSize="9" Margin="0,10,0,0"/>
    </Grid>
</Window>
