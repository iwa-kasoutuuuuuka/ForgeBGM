<Window x:Class="ForgeBGM.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="ForgeBGM - Professional AI Music Suite" Height="900" Width="1300"
        Background="#0A0B10" Foreground="#F8FAFC"
        Icon="/Resources/AppIcon.png">
    <Window.Resources>
        <!-- Custom Styles (Reuse from v1.3 but enhanced) -->
        <Style x:Key="GlassCard" TargetType="Border">
            <Setter Property="Background" Value="#191B26"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderBrush" Value="#22FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="20" Color="Black" Opacity="0.3" ShadowDepth="4"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#4F46E5"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="15,8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Forge" FontSize="26" FontWeight="ExtraBold" Foreground="White"/>
                <TextBlock Text="BGM" FontSize="26" FontWeight="ExtraBold" Foreground="#4F46E5"/>
                <Border Background="#4F46E5" CornerRadius="4" Margin="10,0,0,0" Padding="6,2" VerticalAlignment="Center">
                    <TextBlock Text="v3.0 GOLD" FontSize="10" Foreground="White" FontWeight="Bold"/>
                </Border>
                <TextBlock x:Name="TxtUpdateStatus" Text="" Foreground="#F59E0B" FontSize="11" VerticalAlignment="Center" Margin="20,0,0,0"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                <Button Content="⚙ SKILL Editor" Background="Transparent" Foreground="#94A3B8" BorderBrush="#33FFFFFF" 
                        BorderThickness="1" Margin="0,0,10,0" Padding="10,2" Click="SkillEditor_Click"/>
                <Button x:Name="LangBtn" Content="JP / EN" Background="Transparent" Foreground="#94A3B8" 
                        BorderBrush="#33FFFFFF" BorderThickness="1" Padding="10,2" Click="LangBtn_Click"/>
            </StackPanel>
        </DockPanel>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Column 1: History -->
            <Border Grid.Column="0" Style="{StaticResource GlassCard}" Padding="10">
                <DockPanel>
                    <TextBlock x:Name="TxtHistoryHeader" Text="🕒 History" FontSize="16" FontWeight="Bold" Margin="0,0,0,10" DockPanel.Dock="Top"/>
                    <ListBox x:Name="HistoryList" Background="Transparent" BorderThickness="0" Foreground="#CBD5E1" SelectionChanged="HistoryList_SelectionChanged"/>
                </DockPanel>
            </Border>

            <!-- Column 2: Control & Visualizer -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource GlassCard}" Padding="15">
                    <StackPanel>
                        <TextBlock x:Name="TxtInputHeader" Text="🎹 Input Prompt" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                        <ComboBox x:Name="ModelSelector" Width="180" HorizontalAlignment="Left" Margin="0,0,0,10">
                            <ComboBoxItem Content="Standard (v2.0)"/>
                            <ComboBoxItem Content="HeartMuLa"/>
                            <ComboBoxItem Content="ACE-Step"/>
                        </ComboBox>
                        <TextBox x:Name="UserInput" Height="100" AcceptsReturn="True" TextWrapping="Wrap" Background="#080808" Foreground="White" Padding="8"/>
                        <Button x:Name="GenerateBtn" Content="Total Produce" Style="{StaticResource PrimaryButton}" Margin="0,10,0,0" Click="GenerateBtn_Click"/>
                    </StackPanel>
                </Border>

                <!-- Local AI & Visualizer -->
                <Border Grid.Row="1" Style="{StaticResource GlassCard}" Padding="15">
                    <StackPanel>
                        <TextBlock x:Name="TxtLocalEngineHeader" Text="🤖 Local AI &amp; Visualizer" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                        
                        <!-- Visualizer Canvas -->
                        <Border Background="#050505" Height="80" CornerRadius="4" Margin="0,0,0,10" BorderBrush="#11FFFFFF" BorderThickness="1">
                            <Canvas x:Name="VisualizerCanvas" ClipToBounds="True"/>
                        </Border>

                        <Button x:Name="LocalGenBtn" Content="Generate &amp; Play (Local)" Height="40" Background="#10B981" Foreground="White" BorderThickness="0" Click="LocalGenBtn_Click"/>
                        <ProgressBar x:Name="GenProgress" Height="4" Margin="0,10,0,0" Foreground="#10B981" Background="#080808" BorderThickness="0" Maximum="1"/>
                        <TextBlock x:Name="TxtStatus" Text="Ready to Forge" FontSize="10" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Active Skills -->
                <Border Grid.Row="2" Style="{StaticResource GlassCard}" Padding="15">
                    <StackPanel>
                        <TextBlock x:Name="TxtSkillHeader" Text="⚡ Active SKILLs" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                        <ItemsControl x:Name="SkillList">
                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#1A10B981" BorderBrush="#4D10B981" BorderThickness="1" CornerRadius="6" Padding="8,4" Margin="0,0,8,8">
                                        <TextBlock Text="{Binding Name}" Foreground="#10B981" FontSize="11"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Column 3: Output Tabs -->
            <Border Grid.Column="2" Style="{StaticResource GlassCard}" Padding="10">
                <TabControl Background="Transparent" BorderThickness="0">
                    <TabItem x:Name="TabMusic" Header="🎵 Music">
                        <StackPanel Margin="0,10,0,0">
                            <TextBox x:Name="PromptOutput" Height="150" IsReadOnly="True" TextWrapping="Wrap" Background="#080808" Foreground="#A5F3FC" Padding="8"/>
                            <TextBlock Text="Generation Report" Margin="0,10,0,5" Foreground="#94A3B8"/>
                            <TextBox x:Name="ReportOutput" Height="250" IsReadOnly="True" TextWrapping="Wrap" Background="#080808" Foreground="#CBD5E1" Padding="8"/>
                        </StackPanel>
                    </TabItem>
                    <TabItem x:Name="TabLyrics" Header="✍ Lyrics">
                        <TextBox x:Name="LyricsOutput" Height="450" IsReadOnly="True" TextWrapping="Wrap" Background="#080808" Foreground="#E2E8F0" Padding="15" FontSize="13" FontStyle="Italic"/>
                    </TabItem>
                    <TabItem x:Name="TabArt" Header="🎨 Visual Art">
                        <TextBox x:Name="ArtOutput" Height="450" IsReadOnly="True" TextWrapping="Wrap" Background="#080808" Foreground="#F472B6" Padding="15"/>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>

        <!-- Footer -->
        <TextBlock Grid.Row="2" Text="© 2026 ForgeBGM Professional GOLD Edition. Local AI Engine Enabled." 
                   HorizontalAlignment="Center" Foreground="#94A3B8" FontSize="9" Margin="0,10,0,0"/>
    </Grid>
</Window>
